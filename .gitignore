###############################################################################
# Git 忽略 / 放行规则说明（维护必读）
#
# 1. 本工程采用“先忽略，后放行（白名单）”策略
#    - 默认忽略工具生成物、缓存、工程状态文件
#    - 仅通过 `!` 明确放行：手写源码 / 约束 / Tcl / IP 描述文件
#
# 2. 忽略规则自上而下匹配
#    - 先命中的规则生效
#    - 后面的 `!` 用于对已忽略路径进行反向放行
#
# 3. 重要限制：
#    - 如果一个目录被整体忽略（如 `Prj/`）
#      则该目录下的任何文件都无法再被放行
#
# 4. 可部分保留的目录，必须使用如下写法：
#      Dir/*
#      !Dir/keep_subdir/
#      !Dir/keep_subdir/**/*.c
#
# 5. 判断文件是否应提交的原则：
#    - 能由 Tcl / 工具自动生成的 → 忽略
#    - 无法自动生成、人工维护的 → 放行
#
# 6. Prj/ 目录说明：
#    - Vivado 工程目录，仅作为本地工作区
#    - 工程必须可通过 Tcl 脚本完整重建
###############################################################################

###############################################################################
# 1. 系统 / 编辑器临时文件
###############################################################################
.DS_Store
Thumbs.db
*.tmp
*.swp
*.bak
*.~*

###############################################################################
# 1. Doc - 参考资料目录（整目录忽略，不留后门）
###############################################################################
Doc/*
!Doc/**/*.md        # 放行 Markdown 文档
!Doc/**/*.pdf       # 放行 PDF 文档
!Doc/**/*.docx     # 放行 Word 文档
!Doc/**/*.xlsx     # 放行 Excel 文档
!Doc/**/*.vsdx     # 放行 Visio 文档
###############################################################################
# 2. Prj - Vivado 工程目录（整目录忽略，不留后门）
###############################################################################
Prj/*

###############################################################################
# 3. Vivado 通用生成物（散落在各目录）
###############################################################################
**/.Xil/
**/.cache/
**/.runs/
**/.gen/
**/.hw/
**/.sim/
**/.ip_user_files/
*.jou
*.log

###############################################################################
# 4. MATLAB（默认只保留 .m）
###############################################################################
Mat/*
!Mat/**/*.m        # 放行 MATLAB 源码
Mat/*.asv
Mat/slprj/
Mat/*.slxc

###############################################################################
# 5. RTL / 仿真源码（白名单模式）
###############################################################################
Rtl/*
!Rtl/HDL/
!Rtl/HDL/**/*.v
!Rtl/HDL/**/*.sv

!Rtl/SIM/
!Rtl/SIM/**/*.sv

###############################################################################
# 6. IP 相关（只保留“描述性文件”）
###############################################################################
Rtl/ip_repo/*
!Rtl/ip_repo/**/component.xml   # IP 核描述文件（必须提交）

Rtl/IP/*
!Rtl/IP/**/*.xcix               # 打包好的 IP(可复用)
# 放行 IP 必需源文件
!Rtl/IP/**/component.xml
!Rtl/IP/**/*.xci
!Rtl/IP/**/*.xdc
!Rtl/IP/**/*.v
!Rtl/IP/**/*.sv
!Rtl/IP/**/*.vhd
!Rtl/IP/**/*.vh


Rtl/TCL_IPS/* # 忽略整个TCL_IPS目录
!Rtl/TCL_IPS/**/*.tcl # 但放行其中的所有 .tcl 文件

###############################################################################
# 7. 约束文件（必须提交）
###############################################################################
Rtl/XDC/*            # 忽略整个 XDC 目录
!Rtl/XDC/**/*.xdc    # 但放行其中的所有 .xdc 文件

###############################################################################
# 8. Tcl 工程脚本（必须提交）
###############################################################################
Tcl/*
!Tcl/**/*.tcl

###############################################################################
# 9. SDK / Vitis（默认全部忽略，按需放行）
###############################################################################
!Sdk/*

# ===== 如果你将来想提交 PS 源码，只需要打开下面几行 =====
# !Sdk/app_src/
# !Sdk/app_src/**/*.c
# !Sdk/app_src/**/*.h
# !Sdk/bsp_cfg/

###############################################################################
# 10. others（杂项，默认忽略）
###############################################################################
others/*
