##################################################################
# CREATE IP Rx_ReSample_FIR_F2
##################################################################

set fir_compiler Rx_ReSample_FIR_F2
create_ip -name fir_compiler -vendor xilinx.com -library ip -version 7.2 -module_name $fir_compiler

write_fir_compiler_FIR_F2  [file join [get_property IP_DIR [get_ips $fir_compiler]] FIR_F2.coe]
set_property -dict { 
  CONFIG.CoefficientSource {COE_File}
  CONFIG.Coefficient_File {FIR_F2.coe}
  CONFIG.Coefficient_Sets {1}
  CONFIG.Coefficient_Sign {Signed}
  CONFIG.Quantization {Integer_Coefficients}
  CONFIG.Coefficient_Width {16}
  CONFIG.Coefficient_Fractional_Bits {0}
  CONFIG.Coefficient_Structure {Inferred}
  CONFIG.Data_Width {16}
  CONFIG.Output_Width {32}
  CONFIG.Has_ARESETn {true}
} [get_ips $fir_compiler]

